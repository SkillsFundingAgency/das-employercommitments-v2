@inject ILinkGenerator LinkGenerator
@using SFA.DAS.EmployerCommitmentsV2.Web.Extensions
@using SFA.DAS.EmployerCommitmentsV2.Web.Models.Cohort
@using SFA.DAS.EmployerUrlHelper.Mvc
@model SFA.DAS.EmployerCommitmentsV2.Web.Models.Cohort.IndexViewModel
@{
    ViewData["Title"] = "Apprenticeships";
    ViewBag.Title = "Add an apprentice";
    ViewBag.GaData.Vpv = "/unapproved/add";

     var routeModel = new Dictionary<string, string>
    {
        {nameof(Model.AccountHashedId), Model.AccountHashedId },
        {"apprenticeshipSessionKey", Model.ApprenticeshipSessionKey.ToString() },
    };
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">Add a learner or send a learner request</h1>

        <p class="govuk-body">Add a learner yourself, or send a request to your training provider to add learners.</p>

        @if (!Model.IsLevyFunded)
        {
            <h2 class="govuk-heading-m">Funding</h2>
            <p class="govuk-body">
                You can choose which funding to use. If you don’t have any funding set up, you will automatically reserve new funds.
            </p>
        }
        
        <h2 class="govuk-heading-m">Permissions</h2>
        <p class="govuk-body">
            If you haven’t already, you can give your training provider permission add learners for you, without you needing to send a request
        </p>
        <p>You’ll still need to approve requests sent to you</p>

        <p class="govuk-body">
            <a asp-external-subdomain="relationships" asp-external-relativeroute="accounts/@Model.AccountHashedId/providers" asp-external-id="@Model.AccountHashedId" asp-external-controller="providers" target="_blank" asp- class="govuk-link">
                View your training provider permissions (opens in new tab)
            </a>
        </p>

        <h2 class="govuk-heading-m">What you'll need</h2>

        <p class="govuk-body">You must:</p>
        <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-8">
            <li>have a <b>training provider</b></li>
            <li>know the name of the <b>learner</b></li>
            <li>know the <b>course name</b></li>
            <li>
                have <b>authority to act</b> for the organisation that's named on the contract you have with your
                training provider
            </li>
            <li>make sure the <b>PAYE scheme</b> used to pay for learners is added to your account</li>
        </ul>
        
        <p>
            <a href="@LinkGenerator.YourOrganisationsAndAgreements(Model.AccountHashedId)" class="govuk-link">
                View your organisations (opens in new tab)
            </a>
        </p>

        <p>
            <a href="@LinkGenerator.PayeSchemes(Model.AccountHashedId)" class="govuk-link">
                View your PAYE
                schemes (opens in new tab)
            </a>
        </p>


        <a asp-action="SelectLegalEntity" id="continue-button" asp-all-route-data="routeModel" role="button" draggable="false" class="govuk-button govuk-button--start">
            Start now
            <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19"
                 viewBox="0 0 33 40" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z" />
            </svg>
        </a>
    </div>
    <div class="govuk-grid-column-one-third">
        <partial name="_AddApprenticeUsefulLinks" for="@Model.IsLevyFunded" />
    </div>
</div>

@section Back
{
    @if (Model.Origin == Origin.Reservations)
    {
        var url = Url.ReservationsLink($"accounts/{Model.AccountHashedId}/reservations/");
        <a href="@url" id="back-link" class="govuk-back-link">Back</a>
    }
}