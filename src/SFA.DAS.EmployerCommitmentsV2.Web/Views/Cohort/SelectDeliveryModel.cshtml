@using SFA.DAS.EmployerCommitmentsV2.Web.Models.Cohort
@using SFA.DAS.CommitmentsV2.Types;


@{
    ViewBag.Title = "Select the apprenticeship delivery model";
}

@model SFA.DAS.EmployerCommitmentsV2.Web.Models.Cohort.SelectDeliveryModelViewModel

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <partial name="_ValidationSummary" />

        <h1 class="govuk-heading-xl"> @ViewBag.Title </h1>

        <form method="post">

            @Html.AntiForgeryToken()

            <div class="govuk-form-group">
                <fieldset class="govuk-fieldset" id="radio-lines">
                    @if (!ViewData.ModelState.IsValid)
                    {

                    }

                    <div class="govuk-radios">
                        @foreach (var entity in Model.DeliveryModels)
                        {
                            <div class="govuk-radios__item" id="radio-item-delivery-model">
                                <input class="govuk-radios__input" id="DeliveryModel-@entity.Id" name="DeliveryModel" type="radio" value="@entity.Id">
                                <label class="govuk-label govuk-radios__label" for="DeliveryModel-@entity.Id">
                                    @entity.Name - @entity.Text
                                </label>
                            </div>
                        }
                    </div>
                </fieldset>
            </div>
            <button type="submit" class="govuk-button" id="submit-transfer-connection">Continue</button>
        </form>

    </div>
</div>

@section Back
{
    <a id="back-link" class="govuk-back-link" href="@Url.Action("Index", "Home", new {Model.AccountHashedId})">Back to Apprentices</a>
}


@section Scripts
{
    <script>
        $(document).ready(function () {
            var url = new URL(document.URL);
            var SelectedDeliveryModelId = url.searchParams.get("SelectedDeliveryModelId");
            if (SelectedDeliveryModelId != null) {
                $('#DeliveryModel-' + SelectedDeliveryModelId).attr('checked', true);
            } else {
                $('#DeliveryModel-0' + SelectedDeliveryModelId).attr('checked', true);
            }
        });
    </script>
}